# Copy to .env and adjust. All settings use the CLINICAL_AI_ prefix.

# Seconds a /predict request waits for the worker before returning 504.
CLINICAL_AI_QUEUE_TIMEOUT_SECONDS=30.0

# Number of concurrent workers consuming the inference queue. More workers =
# higher throughput (scales ~linearly); see docs/architecture/performance-baseline.md.
CLINICAL_AI_WORKER_COUNT=4

# Hugging Face model repo id (Task: Image Classification). Verify it exists on
# huggingface.co first. Leave empty to use the placeholder TorchModel (no download).
# Example (VERIFY before use): CLINICAL_AI_MODEL_ID=some-org/vit-chest-xray-pneumonia
CLINICAL_AI_MODEL_ID=
