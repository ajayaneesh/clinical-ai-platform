# Copy to .env and adjust. All settings use the CLINICAL_AI_ prefix.

# Seconds a /predict request waits for the worker before returning 504.
CLINICAL_AI_QUEUE_TIMEOUT_SECONDS=30.0

# Number of batching workers. Keep at 1 (Option A): one worker forms the largest
# batches for a single GPU. Increase only for multiple GPUs (one worker each).
CLINICAL_AI_WORKER_COUNT=1

# Hugging Face model repo id (Task: Image Classification). Verify it exists on
# huggingface.co first. Leave empty to use the placeholder TorchModel (no download).
# Example (VERIFY before use): CLINICAL_AI_MODEL_ID=some-org/vit-chest-xray-pneumonia
CLINICAL_AI_MODEL_ID=

# Batch inference tuning. Worker collects up to MAX_BATCH_SIZE jobs, or waits
# MAX_BATCH_WAIT_MS for the first job's batch to fill, then runs one forward pass.
CLINICAL_AI_MAX_BATCH_SIZE=8
CLINICAL_AI_MAX_BATCH_WAIT_MS=20

# How often (seconds) the background task samples process CPU/memory into the
# process_cpu_percent / process_memory_bytes gauges.
CLINICAL_AI_RESOURCE_SAMPLE_INTERVAL_S=5.0

# Embedding model: "biomedclip" (medical, default) or "laion-clip" (general CLIP).
# Switch to compare general vs. domain embeddings on the same X-rays.
CLINICAL_AI_EMBEDDING_MODEL=biomedclip
